    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.41.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.1",
    "esbuild": "^0.25.12",
